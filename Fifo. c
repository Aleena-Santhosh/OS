#include <stdio.h>
#include <stdlib.h>
#include <time.h>
int search(int key, int frame[], int f) {
    for (int i = 0; i < f; i++) {
        if (frame[i] == key) return 1;
    }
    return 0;
}
int main(int argc, char *argv[]) {
    if (argc != 3) {
        printf("Usage: %s <length> <frames>\n", argv[0]);
        return 0;
    }
    int n = atoi(argv[1]);
    int f = atoi(argv[2]);
    int ref[n], frame[f];
    int faults = 0, pos = 0;
    for (int i = 0; i < f; i++) frame[i] = -1;
    srand(time(0));
    printf("Reference String: ");
    for (int i = 0; i < n; i++) {
        ref[i] = rand() % 10;
        printf("%d ", ref[i]);
    }
    for (int i = 0; i < n; i++) {
        if (!search(ref[i], frame, f)) {
            frame[pos] = ref[i];
            pos = (pos + 1) % f; 
            faults++;
        }
    }
    printf("\nTotal FIFO Faults: %d\n", faults);
    return 0;
}
