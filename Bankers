#include <stdio.h>
#include <stdbool.h>
int main()
{
    int n, m, i, j, c = 0;
    printf("Enter number of processes: ");
    scanf("%d", &n);
    printf("Enter number of resources: ");
    scanf("%d", &m);
    int max[n][m], alloc[n][m], need[n][m], avail[m], safe[n];
    bool finish[n];
    printf("Enter Allocation Matrix (%d x %d):\n", n, m);
    for(i=0;i<n;i++)
        for(j=0;j<m;j++)
            scanf("%d",&alloc[i][j]);
    printf("Enter Maximum Matrix (%d x %d):\n", n, m);
    for(i=0;i<n;i++)
        for(j=0;j<m;j++)
            scanf("%d",&max[i][j]);
    printf("Enter Available Resources (%d):\n", m);
    for(j=0;j<m;j++)
        scanf("%d",&avail[j]);
    for(i=0;i<n;i++)
        for(j=0;j<m;j++)
            need[i][j] = max[i][j] - alloc[i][j];
    for(i=0;i<n;i++) finish[i]=0;
    while(c < n)
    {
        int found = 0;
        for(i=0;i<n;i++)
            if(!finish[i])
            {
                for(j=0;j<m && need[i][j] <= avail[j]; j++);
                if(j == m)
                {
                    for(int k=0;k<m;k++)
                        avail[k] += alloc[i][k];
                    safe[c++] = i;
                    finish[i] = 1;
                    found = 1;
                }
            }
        if(!found)
        {
            printf("System is in an unsafe state!\n");
            return 0;
        }
    }
    printf("System is in a safe state.\n");
    printf("Safe sequence is: ");
    for(i=0;i<n;i++)
    {
        printf("P%d", safe[i]);
        if(i != n-1) printf(" -> ");
    }
    printf("\n");
}
