#include <stdio.h>
int main()
{
    int n, at[50], bt[50], rem[50];
    int t = 0, wt = 0, tq = 3;
    printf("Enter number of processes: ");
    scanf("%d", &n);
    for (int i = 0; i < n; i++)
    {
        printf("\nP%d\n", i + 1);
        printf("Arrival Time: ");
        scanf("%d", &at[i]);
        printf("Burst Time: ");
        scanf("%d", &bt[i]);
        rem[i] = bt[i];
    }
    int done;
    do
    {
        done = 1;
        for (int i = 0; i < n; i++)
        {
            if (rem[i] > 0 && at[i] <= t)
            {
                done = 0;
                if (rem[i] > tq)
                {
                    t += tq;
                    rem[i] -= tq;
                }
                else
                {
                    t += rem[i];
                    wt += t - at[i] - bt[i];
                    rem[i] = 0;
                }
            }
        }
    } while (!done);
    printf("\nAverage Waiting Time = %.2f\n", (float)wt / n);
    return 0;
}
